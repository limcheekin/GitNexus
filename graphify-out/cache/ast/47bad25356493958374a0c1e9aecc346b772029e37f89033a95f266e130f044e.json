 {"caller_nid": "embeddings_embedder_iscudaavailable", "callee": "join", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L89"}, {"caller_nid": "embeddings_embedder_iscudaavailable", "callee": "existsSync", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L90"}, {"caller_nid": "embeddings_embedder_iscudaavailable", "callee": "join", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L90"}, {"caller_nid": "embeddings_embedder_initembedder", "callee": "isHttpMode", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L129"}, {"caller_nid": "embeddings_embedder_initembedder", "callee": "resolveEmbeddingConfig", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L148"}, {"caller_nid": "embeddings_embedder_initembedder", "callee": "(async () => {\n    try {\n      // Configure transformers.js environment\n      env.allowLocalModels = false;\n      // Bridge user-controlled env vars to transformers.js: HF_HOME \u2192\n      // env.cacheDir, HF_ENDPOINT \u2192 env.remoteHost (#1205). Centralised in\n      // applyHfEnvOverrides so the MCP embedder entry point behaves\n      // identically.\n      applyHfEnvOverrides(env);\n\n      const isDev = process.env.NODE_ENV === 'development';\n      if (isDev) {\n        console.log(`\ud83e\udde0 Loading embedding model: ${finalConfig.modelId}`);\n      }\n\n      const progressCallback = onProgress\n        ? (data: any) => {\n            const progress: ModelProgress = {\n              status: data.status || 'progress',\n              file: data.file,\n              progress: data.progress,\n              loaded: data.loaded,\n              total: data.total,\n            };\n            onProgress(progress);\n          }\n        : undefined;\n\n      // Try GPU first if auto, fall back to CPU\n      // Windows: dml (DirectML/DirectX12), Linux: cuda\n      const devicesToTry: Array<'dml' | 'cuda' | 'cpu' | 'wasm'> =\n        requestedDevice === 'dml' || requestedDevice === 'cuda'\n          ? [requestedDevice, 'cpu']\n          : [requestedDevice as 'cpu' | 'wasm'];\n\n      for (const device of devicesToTry) {\n        try {\n          if (isDev && device === 'dml') {\n            console.log('\ud83d\udd27 Trying DirectML (DirectX12) GPU backend...');\n          } else if (isDev && device === 'cuda') {\n            console.log('\ud83d\udd27 Trying CUDA GPU backend...');\n          } else if (isDev && device === 'cpu') {\n            console.log('\ud83d\udd27 Using CPU backend...');\n          } else if (isDev && device === 'wasm') {\n            console.log('\ud83d\udd27 Using WASM backend (slower)...');\n          }\n\n          embedderInstance = await (pipeline as any)('feature-extraction', finalConfig.modelId, {\n            device: device,\n            dtype: 'fp32',\n            progress_callback: progressCallback,\n            session_options: {\n              logSeverityLevel: 3,\n              intraOpNumThreads: finalConfig.threads,\n              interOpNumThreads: 1,\n              executionMode: 'sequential',\n            },\n          });\n          currentDevice = device;\n\n          if (isDev) {\n            const label =\n              device === 'dml'\n                ? 'GPU (DirectML/DirectX12)'\n                : device === 'cuda'\n                  ? 'GPU (CUDA)'\n                  : device.toUpperCase();\n            console.log(`\u2705 Using ${label} backend`);\n            console.log('\u2705 Embedding model loaded successfully');\n          }\n\n          return embedderInstance!;\n        } catch (deviceError) {\n          if (isDev && (device === 'cuda' || device === 'dml')) {\n            const gpuType = device === 'dml' ? 'DirectML' : 'CUDA';\n            console.log(`\u26a0\ufe0f  ${gpuType} not available, falling back to CPU...`);\n          }\n          // Continue to next device in list\n          if (device === devicesToTry[devicesToTry.length - 1]) {\n            throw deviceError; // Last device failed, propagate error\n          }\n        }\n      }\n\n      throw new Error('No suitable device found for embedding model');\n    } catch (error) {\n      isInitializing = false;\n      initPromise = null;\n      embedderInstance = null;\n      throw error;\n    } finally {\n      isInitializing = false;\n    }\n  })", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L157"}, {"caller_nid": "embeddings_embedder_isembedderready", "callee": "isHttpMode", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L259"}, {"caller_nid": "embeddings_embedder_getembeddingdimensions", "callee": "isHttpMode", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L267"}, {"caller_nid": "embeddings_embedder_getembeddingdimensions", "callee": "getHttpDimensions", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L268"}, {"caller_nid": "embeddings_embedder_getembedder", "callee": "isHttpMode", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L277"}, {"caller_nid": "embeddings_embedder_embedtext", "callee": "isHttpMode", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L29