et": "core_embedder_getembeddingdims", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L132", "weight": 1.0}, {"source": "home_limcheekin_dev_ws_ts_gitnexus_gitnexus_src_mcp_core_embedder_ts", "target": "core_embedder_disposeembedder", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L139", "weight": 1.0}, {"source": "core_embedder_embedquery", "target": "core_embedder_initembedder", "relation": "calls", "confidence": "EXTRACTED", "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L119", "weight": 1.0}], "raw_calls": [{"caller_nid": "core_embedder_initembedder", "callee": "isHttpMode", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L30"}, {"caller_nid": "core_embedder_initembedder", "callee": "(async () => {\n    try {\n      env.allowLocalModels = false;\n      // Bridge user-controlled env vars to transformers.js: HF_HOME \u2192\n      // env.cacheDir, HF_ENDPOINT \u2192 env.remoteHost (#1205). Centralised in\n      // applyHfEnvOverrides so this MCP entry point behaves identically to\n      // the analyze pipeline embedder.\n      applyHfEnvOverrides(env);\n      const embeddingConfig = resolveEmbeddingConfig();\n\n      console.error('GitNexus: Loading embedding model (first search may take a moment)...');\n\n      const devicesToTry: Array<'dml' | 'cuda' | 'cpu'> =\n        embeddingConfig.device === 'dml' || embeddingConfig.device === 'cuda'\n          ? [embeddingConfig.device, 'cpu']\n          : ['cpu'];\n\n      for (const device of devicesToTry) {\n        try {\n          // Silence stdout and stderr during model load \u2014 ONNX Runtime and transformers.js\n          // may write progress/init messages that corrupt MCP stdio protocol or produce\n          // noisy warnings (e.g. node assignment to execution providers).\n          // Use the centralized silenceStdout() to avoid conflicts with pool-adapter's\n          // own stdout patching (independent patching caused restore-order bugs).\n          silenceStdout();\n          process.stderr.write = (() => true) as any;\n          try {\n            embedderInstance = await (pipeline as any)('feature-extraction', MODEL_ID, {\n              device: device,\n              dtype: 'fp32',\n              session_options: {\n                logSeverityLevel: 3,\n                intraOpNumThreads: embeddingConfig.threads,\n                interOpNumThreads: 1,\n                executionMode: 'sequential',\n              },\n            });\n          } finally {\n            restoreStdout();\n            process.stderr.write = realStderrWrite;\n          }\n          console.error(`GitNexus: Embedding model loaded (${device})`);\n          return embedderInstance!;\n        } catch {\n          if (device === 'cpu') throw new Error('Failed to load embedding model');\n        }\n      }\n\n      throw new Error('No suitable device found');\n    } catch (error) {\n      isInitializing = false;\n      initPromise = null;\n      embedderInstance = null;\n      throw error;\n    } finally {\n      isInitializing = false;\n    }\n  })", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L44"}, {"caller_nid": "core_embedder_isembedderready", "callee": "isHttpMode", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L109"}, {"caller_nid": "core_embedder_embedquery", "callee": "isHttpMode", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L115"}, {"caller_nid": "core_embedder_embedquery", "callee": "httpEmbedQuery", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L116"}, {"caller_nid": "core_embedder_embedquery", "callee": "embedder", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L121"}, {"caller_nid": "core_embedder_embedquery", "callee": "from", "is_member_call": true, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L126"}, {"caller_nid": "core_embedder_getembeddingdims", "callee": "getHttpDimensions", "is_member_call": false, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L133"}, {"caller_nid": "core_embedder_disposeembedder", "callee": "dispose", "is_member_call": true, "source_file": "/home/limcheekin/dev/ws/ts/GitNexus/gitnexus/src/mcp/core/embedder.ts", "source_location": "L143"}]}